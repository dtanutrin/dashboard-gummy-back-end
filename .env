# Variáveis de Ambiente para o Backend Gummy Dashboards

# --- Configuração do Banco de Dados PostgreSQL ---
# Substitua com a URL de conexão real do seu banco de dados.
# Formato: postgresql://<USUARIO>:<SENHA>@<HOST>:<PORTA>/<NOME_DO_BANCO>?schema=public
DATABASE_URL="postgresql://postgres:sua_senha_aqui@localhost:5432/gummy_dashboards?schema=public"

# --- Configuração de Segurança (JWT) ---
# Substitua por uma string secreta longa, forte e aleatória.
# Use um gerador de senhas seguras para criar isso.
JWT_SECRET="a620acfe4a07842379533140dc4038542b165692929299735d56f08589912552"

# --- Configuração do Servidor ---
# Porta em que o servidor backend irá rodar (pode ser 5000 ou outra de sua preferência)
PORT=5000

